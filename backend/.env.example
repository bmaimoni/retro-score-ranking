# ── Banco de dados ────────────────────────────────────────────────────────────
# String de conexão asyncpg para o Postgres do Supabase
# Encontre em: Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Supabase Storage ──────────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Settings → API
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key (não a anon key)
STORAGE_BUCKET=fotos-ranking

# ── Segurança ─────────────────────────────────────────────────────────────────
# Senha do painel admin — gere com: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=troque-por-um-valor-seguro

# Salt para hash de IP — gere com: python -c "import secrets; print(secrets.token_hex(16))"
IP_HASH_SALT=troque-por-um-salt-seguro

# ── Rate limit ────────────────────────────────────────────────────────────────
# Máximo de uploads por IP na janela de tempo
RATE_LIMIT=3
RATE_WINDOW_SECONDS=3600

# ── CORS ──────────────────────────────────────────────────────────────────────
# URLs do frontend separadas por vírgula
# Ex: https://meu-evento.vercel.app,https://admin.meu-evento.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Ambiente ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development  # development | production
